VITE_PUBLIC_SITE_URL=https://career2day.com
VITE_ENABLE_ADS=false
VITE_PADDLE_CLIENT_TOKEN=
VITE_PADDLE_ENV=sandbox

# CV data is stored in localStorage only. Do not add private API keys to Vite env files.
# Admin login should be protected by a real server-side auth check before production use.
# These demo values are intentionally blank so secrets are not bundled into the frontend.
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD=
